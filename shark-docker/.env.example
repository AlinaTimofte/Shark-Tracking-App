# Copy this file to .env for Docker Compose.
# Generate real values with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"

JWT_SECRET=replace-with-32-random-bytes-base64
ENCRYPTION_KEY=replace-with-32-random-bytes-base64

# Local Postgres example. Docker Compose already sets DATABASE_URL for the app container.
DATABASE_URL=postgres://shark_app:shark_app_password@localhost:5432/shark_tracker
